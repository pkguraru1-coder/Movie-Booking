# ─── MongoDB ───────────────────────────────────────────────
# Option A: Local MongoDB (agar PC pe MongoDB installed hai)
MONGO_URI=mongodb://127.0.0.1:27017/bookmovie

# Option B: MongoDB Atlas (cloud) — upar wali line comment karke ye use karo:
# MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/bookmovie

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET=bookmovie_jwt_super_secret_2024_change_this

# ─── Server ────────────────────────────────────────────────
PORT=5000

# ─── Stripe (optional, payment ke liye) ───────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here

# ─── Frontend URL (CORS ke liye) ──────────────────────────
CLIENT_URL=http://localhost:5173
